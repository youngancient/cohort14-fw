# Web3Auth Configuration
VITE_WEB3AUTH_CLIENT_ID=your_client_id_here
VITE_WEB3AUTH_CLIENT_SECRET=your_client_secret_here
VITE_WEB3AUTH_JWKS_ENDPOINT=your_jwks_endpoint_here

# Environment (devnet or mainnet)
VITE_WEB3AUTH_ENVIRONMENT=devnet

# WalletConnect Project ID (for RainbowKit)
VITE_WALLETCONNECT_PROJECT_ID=demo_excelschool_project

# App Configuration
VITE_APP_NAME=ExcelSchool
